{
  "default": {
    "require": [
      "src/steps/**/*.ts",
      "src/supports/**/*.ts"
    ],
    "requireModule": [
      "ts-node/register"
    ],
    "format": [
      "progress",
      "json:reports/cucumber_report.json",
      "html:reports/cucumber_report.html"
    ],
    "paths": [
      "src/features/**/*.feature"
    ],
    "publishQuiet": true,
    "dryRun": false,
    "tags": "",
    "worldParameters": {},
    "formatOptions": {},
    "parallel": 0
  }
}